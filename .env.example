# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commiter .env dans git

# --- SUPABASE (obligatoire) ---
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Clé service (jamais exposée côté client) — nécessaire pour npm run seed
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- STRIPE (paiement) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND (emails transactionnels) ---
RESEND_API_KEY=re_...
# Expéditeur affiché dans les emails (doit être vérifié sur resend.com)
RESEND_FROM_EMAIL=noreply@shopca.fr
RESEND_FROM_NAME=SHOPCA

# --- MAPBOX (cartographie) ---
VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijo...

# --- APP ---
VITE_APP_URL=https://shopca.fr
VITE_APP_NAME=SHOPCA
VITE_SUPPORT_EMAIL=support@shopca.fr
